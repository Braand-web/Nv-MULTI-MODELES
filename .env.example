# Required in every Vercel project. Generate with `openssl rand -base64 32`.
# NEXTAUTH_SECRET is also accepted for legacy Vercel projects.
AUTH_SECRET=****

# required for non-vercel deployments, vercel uses OIDC automatically
# https://vercel.com/ai-gateway
AI_GATEWAY_API_KEY=****

# optional: route chat and image generation through OpenRouter
OPENROUTER_API_KEY=****

# https://vercel.com/docs/vercel-blob
BLOB_READ_WRITE_TOKEN=****

# https://vercel.com/docs/postgres
POSTGRES_URL=****

# https://vercel.com/docs/redis
REDIS_URL=****

# payment provider used for credit recharges
FAPSHI_API_USER=****
FAPSHI_API_KEY=****
FAPSHI_ENV=sandbox
